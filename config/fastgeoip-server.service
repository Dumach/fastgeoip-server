# /etc/systemd/system/fastgeoip-server.service
# Systemd service file for Uvicorn with Gunicorn

[Unit]
Description=FastGeoIp Service with Uvicorn
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=alex
Group=alex
WorkingDirectory=/home/alex/fastgeoip-server

# Run Gunicorn with Uvicorn workers
Environment="PATH=/usr/local/bin:/usr/bin:/bin"
ExecStart=uv run main.py

# Graceful reload
ExecReload=/bin/kill -s HUP $MAINPID

# Restart policy
Restart=on-failure
RestartSec=5

# Security hardening
#NoNewPrivileges=true
#PrivateTmp=true
#ProtectSystem=strict
#ProtectHome=true
#ReadWritePaths=/var/run/uvicorn /var/log/uvicorn

# Resource limits
LimitNOFILE=65535
LimitNPROC=65535

[Install]
WantedBy=multi-user.target